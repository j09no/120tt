{
   "manifest_version": 3,
   "name": "TikTok HQ Upload (Personal)",
   "description": "Preserves original quality (1080p/2K/4K @ 60/120fps) on TikTok web uploads by sanitizing the upload payload locally. No telemetry.",
   "version": "1.0.0",
   "action": {
      "default_popup": "popup.html",
      "default_title": "TikTok HQ Upload"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://www.tiktok.com/*" ],
      "run_at": "document_start"
   } ],
   "host_permissions": [ "https://www.tiktok.com/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "permissions": [ "scripting", "activeTab", "storage" ],
   "web_accessible_resources": [ {
      "matches": [ "https://www.tiktok.com/*" ],
      "resources": [ "inject.js" ]
   } ]
}
